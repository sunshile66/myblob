{
  "name": "blog-frontend",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "vite",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"node ./node_modules/typescript/bin/tsc --noEmit; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; node ./node_modules/vite/bin/vite.js build\"",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "element-plus": "^2.5.0",
    "fabric": "^7.2.0",
    "markdown-it": "^14.0.0",
    "marked": "^17.0.4",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "sass-embedded": "^1.98.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  }
}
